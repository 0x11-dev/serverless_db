# Serverless DB - Environment Configuration
# Copy this file to .env and fill in strong random secrets.
# NEVER commit the real .env file to the repository.

# Set to "production" to enforce strict security (no default JWT secret, no wildcard CORS, token minting disabled)
SDB_ENV=production

# JWT secret for signing/verifying tokens. Generate with: openssl rand -hex 32
SDB_JWT_SECRET=

# S3/RustFS root credentials. Generate with: openssl rand -hex 16
S3_ROOT_USER=
S3_ROOT_PASSWORD=

# CORS allowed origins (comma-separated). In production, set explicit origins.
# Example: https://your-app.example.com,https://admin.example.com
SDB_CORS_ORIGINS=

# Project configuration
SDB_S3_BUCKET=serverless-db-poc
SDB_S3_PREFIX=distributed-poc
SDB_PROJECT_ID=demo
